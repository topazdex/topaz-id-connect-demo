# RainbowKit requires a WalletConnect (Reown) project id for its config.
# The Topaz ID connector itself uses a popup flow and does NOT use WalletConnect,
# but connectorsForWallets still needs this value. Get one free at https://cloud.reown.com.
NEXT_PUBLIC_WC_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Token offered in the swap card, paired against BNB. Defaults to TOPAZ.
# Point this at your own token's contract address to make the demo swap it instead.
# Symbol + decimals are read on-chain; price + logo come from Dexscreener.
# NEXT_PUBLIC_SWAP_TOKEN_ADDRESS=0xdf002282C1474C9592780618Adda7EaA99998Abd

# Optional: pin the tick spacing of the WBNB/<token> CL pool on Topaz.
# Leave unset to auto-detect across the standard spacings (200, 100, 50, 2000, 1).
# NEXT_PUBLIC_SWAP_TICK_SPACING=200
